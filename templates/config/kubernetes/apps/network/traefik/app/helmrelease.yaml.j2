---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: traefik
spec:
  chartRef:
    kind: OCIRepository
    name: traefik
  interval: 1h
  values:
    deployment:
      replicas: 2
    providers:
      kubernetesGateway:
        enabled: true
    service:
      spec:
        externalTrafficPolicy: Cluster
      annotations:
        lbipam.cilium.io/ips: "#{ cloudflare_gateway_addr }#"
      additionalServices:
        private:
          type: LoadBalancer
          annotations:
            lbipam.cilium.io/ips: "#{ cluster_gateway_addr }#"
          spec:
            externalTrafficPolicy: Cluster
    ports:
      web:
        asDefault: true
        redirections:
          entryPoint:
            to: websecure
            scheme: https
            permanent: true
      websecure:
        tls:
          enabled: true
    gatewayClass:
      enabled: false
    gateway:
      enabled: false
    ingressClass:
      enabled: false
    ingressRoute:
      dashboard:
        enabled: false
    metrics:
      prometheus:
        service:
          enabled: true
        serviceMonitor:
          enabled: true
          namespace: observability
    logs:
      access:
        enabled: true
        addInternals: true
    api:
      dashboard: true
