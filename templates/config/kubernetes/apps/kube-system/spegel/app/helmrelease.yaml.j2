---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: spegel
spec:
  chartRef:
    kind: OCIRepository
    name: spegel
  interval: 1h
  values:
    spegel:
      containerdSock: /run/containerd/containerd.sock
      containerdRegistryConfigPath: /etc/containerd/certs.d
      mirroredRegistries:
        - https://docker.io
        - https://ghcr.io
        - https://quay.io
        - https://registry.k8s.io
        - https://gcr.io
    service:
      registry:
        hostPort: 30020
    serviceMonitor:
      enabled: true
